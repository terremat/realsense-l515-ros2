# ROS 2 network configuration loaded by scripts/run.sh.
#
# Use the host network interface while keeping isolation via ROS_DOMAIN_ID.
# This avoids CycloneDDS loopback-only edge cases while staying off domain 0.
ROS_LOCALHOST_ONLY=0

# Keep ROS traffic separated from other ROS systems on the same network.
# Use this same value in host terminals that should see the container.
ROS_DOMAIN_ID=42

# ROS 2 Jazzy/Rolling and newer can use this instead of ROS_LOCALHOST_ONLY.
# Leave it commented for Humble compatibility.
# ROS_AUTOMATIC_DISCOVERY_RANGE=LOCALHOST

# Default middleware used by this image.
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Avoid stale or incomplete ROS 2 CLI graph cache while debugging Docker/DDS.
ROS_DISABLE_DAEMON=1
